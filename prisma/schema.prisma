generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model academic_researchers {
  id           BigInt  @id @default(autoincrement())
  name         String?
  affiliation  String?
  main_topic   String?
  subtopics    String?
  scholar_id   String?
  h_index      Int?    @default(0)
  works_count  Int?    @default(0)
  openalex_url String?
  titles       String?
  subtitles    String?
  co_authors   String?
  keywords     String?
  concepts     String?
  institutions String?
}

model applications {
  id             BigInt    @id @default(autoincrement())
  jobid          Int?
  applicantname  String?
  applicantemail String?
  applicantphone String?
  cvpath         String?
  timestamp      DateTime? @default(now()) @db.Timestamptz(6)
}

model companies {
  id         BigInt  @id @default(autoincrement())
  name       String?
  category   String?
  industry   String?
  size       String?
  website    String?
  linkedin   String?
  branches   Json?
  hq_country String?
  glassdoor  String?
}

model feedback {
  id           BigInt    @id @default(autoincrement())
  name         String?
  email        String?
  category     String?
  message      String?
  submitted_at DateTime? @default(now()) @db.Timestamptz(6)
}

model graduation_projects {
  id              BigInt    @id @default(autoincrement())
  student_name    String?
  email           String?
  phone           String?
  university      String?
  faculty         String?
  major           String?
  supervisor      String?
  co_supervisor   String?
  is_sponsored    Boolean?  @default(false)
  sponsor_company String?
  company_mentor  String?
  grad_year       Int?
  domains         String?
  project_title   String?
  peers_count     Int?
  doc_link        String?
  submitted_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model hot_topics {
  id          BigInt  @id @default(autoincrement())
  title       String?
  description String?
  field       String?
  type        String?
  status      String?
  tags        String?
  link        String?
  priority    Int?    @default(0)
}

model jobs {
  id               BigInt    @id @default(autoincrement())
  owner_id         Int?
  title            String?
  company          String?
  country          String?
  country_code     String?
  track            String?
  type             String?
  seniority        String?
  description      String?
  requirements     String?
  salary           String?
  apply_link       String?
  posted_at        DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  is_active        Boolean?  @default(true)
  is_fully_scraped Boolean?  @default(false)
}

model profiles {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               BigInt?
  full_name             String?
  gender                String?
  country               String?
  governorate           String?
  university            String?
  faculty               String?
  department            String?
  graduation_year       Int?
  university_email      String?
  linkedin_url          String?
  github_url            String?
  scholar_url           String?
  skills                Json?     @default("[]")
  experience            Json?     @default("[]")
  internships           Json?     @default("[]")
  courses               Json?     @default("[]")
  personal_projects     Json?     @default("[]")
  graduation_project    Json?     @default("{}")
  postgraduate_research Json?     @default("{}")
  iti_training          Json?     @default("{}")
  nti_training          Json?     @default("{}")
  created_at            DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  bio                   String?
  avatar_url            String?
  users                 users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_profiles_user_id")
}

model users {
  id          BigInt     @id @default(autoincrement())
  name        String?
  email       String?    @unique
  password    String?
  role        String?
  is_approved Int?       @default(0)
  profiles    profiles[]
}
